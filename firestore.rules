rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the requesting user is a verified school administrator
    function isRegistrar() {
      return request.auth != null;
    }

    // 1. School Administrator registers collection rules
    match /hgs_administrators/{adminId} {
      // Allow first admin setup and check if admins exist, and read matching profile on login
      allow create, read: if true; 
      allow update, delete: if request.auth != null && request.auth.uid == adminId;
    }

    // 2. Public admission applications registration collection rules
    match /hgs_admissions/{admissionId} {
      // Public visitors can submit online application forms and read their profiles.
      // Authenticated admin operators can read and manage without restriction.
      allow create, read: if true;
      allow update, delete: if request.auth != null;
    }

    // 3. Pupil Ledger & Accounts Database compilation rules
    match /hgs_students/{studentId} {
      // Verified Registrars can modify records
      allow create, update, delete: if request.auth != null;
      // Allow reading so that students can check report sheets and authenticate
      allow read: if true;
    }

    // 4. Contact desk feedback inquiry archives
    match /hgs_messages/{messageId} {
      // Visitors can securely submit inquiry reports
      allow create: if true;
      // Master registers restricted to administrative review
      allow read, update, delete: if request.auth != null;
    }

    // 5. Audit Activity log audits
    match /hgs_activity_logs/{logId} {
      // Registrar can read/write logs
      allow create, read, update, delete: if request.auth != null;
    }

    // 6. System audit logs (V2)
    match /system_audit_logs/{logId} {
      allow create, read, update, delete: if request.auth != null;
    }

    // 7. CBT and Notifications collections
    match /cbt_exams/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    match /cbt_questions/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    match /cbt_results/{id} {
      allow read, write: if true;
    }
    match /cbt_answers/{id} {
      allow read, write: if true;
    }
    match /teacher_results/{id} {
      allow read, write: if true;
    }
    match /hgs_notices/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
